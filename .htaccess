# ChinaBuyHub - Apache Configuration Options -Indexes # COMPRESSION <IfModule mod_deflate.c> AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/rss+xml image/svg+xml # Remove browser bugs BrowserMatch ^Mozilla/4 gzip-only-text/html BrowserMatch ^Mozilla/4\.0[678] no-gzip BrowserMatch \bMSIE !no-gzip !gzip-only-text/html Header append Vary User-Agent </IfModule> # BROWSER CACHE <IfModule mod_expires.c> ExpiresActive On ExpiresByType image/jpg "access plus 1 year" ExpiresByType image/jpeg "access plus 1 year" ExpiresByType image/png "access plus 1 year" ExpiresByType image/webp "access plus 1 year" ExpiresByType image/svg+xml "access plus 1 year" ExpiresByType image/x-icon "access plus 1 year" ExpiresByType text/css "access plus 1 year" ExpiresByType application/javascript "access plus 1 year" ExpiresByType application/x-font-woff2 "access plus 1 year" ExpiresByType application/font-woff2 "access plus 1 year" ExpiresDefault "access plus 1 month" </IfModule> <IfModule mod_headers.c> <FilesMatch "\.(css|js|jpg|jpeg|png|webp|svg|ico|woff2)$"> Header set Cache-Control "public, max-age=31536000, immutable" </FilesMatch> </IfModule> # SECURITY HEADERS <IfModule mod_headers.c> Header always set X-Content-Type-Options "nosniff" Header always set X-Frame-Options "SAMEORIGIN" Header always set Referrer-Policy "strict-origin-when-cross-origin" Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()" Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups" Header always set Cross-Origin-Resource-Policy "same-origin" Header always set Content-Security-Policy "default-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://si.geilicdn.com https://*.google-analytics.com https://www.googletagmanager.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://*.google-analytics.com https://giscus.app; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.google-analytics.com https://litbuy.com https://ikako.vip https://api.groq.com https://api.giscus.app; frame-src 'self' https://giscus.app https://www.youtube.com https://www.google.com/maps" </IfModule> <IfModule mod_rewrite.c> RewriteEngine On # FORCE HTTPS + WWW (Hostinger) RewriteCond %{HTTP:X-Forwarded-Proto} !https [OR] RewriteCond %{HTTP_HOST} !^www\.chinabuyhub\.com$ [NC] RewriteRule ^(.*)$ https://www.chinabuyhub.com/$1 [L,R=301] # REDIRECT OLD CATEGORY PAGES (/c/*) TO MAIN CATALOG RewriteRule ^c/.*$ /catalog [L,R=301] # NEVER REWRITE XML/STATIC FILES RewriteRule \.(xml|txt|pdf|zip|gz|json)$ - [L] # SERVE PRODUCT DETAIL PAGES: /product/ID -> product.html RewriteRule ^product/([^/]+)/?$ product.html [L] # REDIRECT OLD PRODUCT URLS (/p/ID -> /product/ID, /p/ -> /catalog) RewriteRule ^p/([^/]+)/?$ /product/$1 [L,R=301] RewriteRule ^p/?$ /catalog [L,R=301] RewriteRule ^p/.*$ /catalog [L,R=301] RewriteRule ^p/?$ /catalog [L,R=301] # REDIRECT OLD URLs # cost-calculator is now a dedicated root page (cost-calculator.html), handled by clean URL rules below RewriteRule ^blog/finds-es/?$ /finds-es [L,R=301] RewriteRule ^catalogo/?$ /catalog [L,R=301] RewriteRule ^agentes(\.html?)?$ /agents [L,R=301] RewriteRule ^guias(/.*)?$ /blog/how-to-buy [L,R=301] RewriteRule ^weidian-guide/?$ /blog/weidian-guide [L,R=301] RewriteRule ^taobao-guide/?$ /blog/taobao-guide [L,R=301] RewriteRule ^1688-guide/?$ /blog/1688-guide [L,R=301] RewriteRule ^shipping-from-china/?$ /blog/shipping-from-china [L,R=301] RewriteRule ^tools_new\.html?$ /tools [L,R=301] RewriteRule ^cookies(\.html?)?$ /legal [L,R=301] RewriteRule ^blog/how-to-buy-with-usfans/?$ /blog/how-to-buy [L,R=301] RewriteRule ^blog/usfans-agent-review/?$ /blog/best-chinese-shopping-agents [L,R=301] RewriteRule ^blog/usfans-qc-photos/?$ /blog/how-to-quality-check-qc [L,R=301] RewriteRule ^blog/usfans-referral-code/?$ /blog/referral-codes-all-agents [L,R=301] RewriteRule ^blog/usfans-shipping-costs/?$ /blog/shipping-from-china [L,R=301] RewriteRule ^blog/usfans-vs-alternatives/?$ /blog/pandabuy-alternatives [L,R=301] RewriteRule ^blog/usfans-vs-pandabuy/?$ /blog/pandabuy-alternatives [L,R=301] RewriteRule ^blog/kakobuy-vs-usfans/?$ /blog/kakobuy-review [L,R=301] RewriteRule ^blog/ChinaBuyHub-qc-photos/?$ /blog/how-to-quality-check-qc [L,R=301] RewriteRule ^blog/ChinaBuyHub-referral-code/?$ /blog/referral-codes-all-agents [L,R=301] RewriteRule ^blog/ChinaBuyHub-shipping-costs/?$ /blog/shipping-from-china [L,R=301] RewriteRule ^blog/ChinaBuyHub-vs-alternatives/?$ /blog/pandabuy-alternatives [L,R=301] RewriteRule ^blog/ChinaBuyHub-vs-pandabuy/?$ /blog/pandabuy-alternatives [L,R=301] RewriteRule ^blog/how-to-buy-with-ChinaBuyHub/?$ /blog/how-to-buy [L,R=301] RewriteRule ^blog/kakobuy-vs-ChinaBuyHub/?$ /blog/kakobuy-review [L,R=301] # BLOG DIRECTORY - force trailing slash so /blog serves blog/index.html
RewriteRule ^blog$ /blog/ [L,R=301]
# REMOVE .html FROM URLS RewriteCond %{THE_REQUEST} \s/([^\s]+)\.html\s [NC] RewriteCond %{REQUEST_URI} !^/404\.html$ RewriteRule ^([^/]+)\.html$ /$1 [L,R=301] # REDIRECT index.html.html (renamed file) to / RewriteRule ^index\.html\.html$ / [L,R=301] # REMOVE index.html RewriteCond %{THE_REQUEST} \s/index\.html\s [NC] RewriteRule ^index\.html$ / [L,R=301] # CLEAN URLs - subfolders /blog/ and /c/ RewriteCond %{ENV:REDIRECT_STATUS} ^$ RewriteCond %{REQUEST_FILENAME} !-f RewriteCond %{REQUEST_FILENAME} !-d RewriteCond %{REQUEST_FILENAME}.html -f RewriteRule ^([^/]+)/([^/]+)/?$ $1/$2.html [NC,L] # CLEAN URLs - root RewriteCond %{ENV:REDIRECT_STATUS} ^$ RewriteCond %{REQUEST_FILENAME} !-f RewriteCond %{REQUEST_FILENAME} !-d RewriteCond %{REQUEST_FILENAME}.html -f RewriteRule ^([^/]+)/?$ $1.html [NC,L] # BLOCK /api/ RewriteRule ^api/.*$ - [G,L] </IfModule> # CUSTOM 404 PAGE ErrorDocument 404 /404.html # PROTECT HIDDEN FILES <FilesMatch "^\."> Order allow,deny Deny from all </FilesMatch> # PROTECT .env FILES (API keys must never be served over HTTP) <FilesMatch "\.env"> Require all denied </FilesMatch> AddDefaultCharset UTF-8 # SITEMAP — force XML content type (prevents Google Search Console "HTML" error) <Files "sitemap.xml"> Header set Content-Type "application/xml; charset=UTF-8" </Files> # CORRECT MIME TYPES <IfModule mod_mime.c> AddType application/xml .xml AddType text/css .css AddType application/javascript .js AddType image/svg+xml .svg </IfModule>